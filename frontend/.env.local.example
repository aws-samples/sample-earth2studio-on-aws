# Frontend environment configuration.
# Copy this file to .env.local and fill in the values from the
# `npx cdk deploy Earth2UI` outputs.
#
#   cp frontend/.env.local.example frontend/.env.local

# Set to "true" to bypass Cognito (uses mocked auth) for local UI development.
VITE_DEV_MODE=false

# From the Earth2UI CDK stack outputs:
#   UserPoolId        → VITE_USER_POOL_ID
#   UserPoolClientId  → VITE_USER_POOL_CLIENT_ID
VITE_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
